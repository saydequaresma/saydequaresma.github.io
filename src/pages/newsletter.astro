---
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import Layout from "@/layouts/Layout.astro";

const account = import.meta.env.PUBLIC_MAILERLITE_ACCOUNT;
const form = import.meta.env.PUBLIC_MAILERLITE_FORM;
const action = `https://assets.mailerlite.com/jsonp/${account}/forms/${form}/subscribe`;
---

<Layout title="Newsletter">
  <Header />
  <main id="main-content" class="mx-auto w-full max-w-3xl px-4 pb-4">
    <section class="pt-10 pb-8">
      <h1 class="my-2 text-2xl font-bold sm:my-4 sm:text-3xl">Newsletter</h1>
      <p class="mt-2">
        Notas ocasionais sobre o que ando a construir. Sem spam, sem ruído.
        Cancelas quando quiseres com um clique.
      </p>

      <form action={action} method="post" target="_blank" class="mt-6 flex flex-col gap-3 max-w-md">
        <label for="email" class="sr-only">Email</label>
        <input
          type="email"
          id="email"
          name="fields[email]"
          required
          autocomplete="email"
          placeholder="tu@exemplo.pt"
          class="px-3 py-2 border rounded"
        />

        <input type="hidden" name="ml-submit" value="1" />
        <input type="hidden" name="anticsrf" value="true" />

        <button type="submit" class="px-4 py-2 bg-accent text-white rounded">
          Subscrever
        </button>

        <p class="text-sm">
          Ao subscrever aceitas a <a href="/privacidade" class="underline">política de privacidade</a>.
        </p>
      </form>
    </section>
  </main>
  <Footer />
</Layout>
